# Backend Environment Variables
PORT=3000
NODE_ENV=development

# Supabase (https://app.supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI API (uses gemini-1.5-flash — cheap!)
GEMINI_API_KEY=your-gemini-api-key-here

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Allowed Origins (your extension ID)
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here

# AI Scan Limit for Premium users (150/day = ~$0.20/user/month with Flash)
PREMIUM_TIER_DAILY_LIMIT=150

# Landing page URL (for upgrade redirect messages)
PRICING_PAGE_URL=https://your-site.github.io/focusguard#pricing
